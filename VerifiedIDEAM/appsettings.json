{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AppSettings": {
    "KeyIdentifier": "https://<your-keyvault>.vault.azure.net/keys/<certOrKeyName>/<version>",
    "CertificateIdentifier": "https://<your-keyvault>.vault.azure.net/certificates/<certName>/<version>"
  },

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "<your-domain>.onmicrosoft.com",
    "TenantId": "...tenant id...",
    "ClientId": "...app id that has access to Key Vault...",
    "ClientSecret": "...secret..."
  },

  "VerifiedID": {
    "ApiEndpoint": "https://verifiedid.did.msidentity.com/v1.0/verifiableCredentials/",
    "ClientId": "...app id with Verified ID permissions...",
    "ClientSecret": "...secret...",
    "scope": "3db474b9-6a0c-4840-96ac-1fceb342124f/.default",
    "ManagedIdentity": false,
    "DIDAuthority": "did:web:<your-domain>",
    "client_name": "Entra Verified ID MFA",
    "Purpose": "To issue your identity",
    "CacheExpiresInSeconds": 600
  },

  "OIDC": {
    "CertificatePassword": "",
    "IdTokenLifetime": 3600,
    "redirect_uri": "https://login.microsoftonline.com/common/federation/externalauthprovider"
  }

}
